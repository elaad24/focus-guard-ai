{
  "name": "focus-guard-ai",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "ensure-deps": "node scripts/ensure-deps.mjs",
    "predev": "npm run ensure-deps",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "run-script-os",
    "dev:backend:win32": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "dev:backend:darwin": "bash scripts/start-backend.sh",
    "dev:backend:linux": "bash scripts/start-backend.sh",
    "dev:frontend": "npm --prefix frontend run dev",
    "setup:backend": "run-script-os",
    "setup:backend:win32": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-backend.ps1",
    "setup:backend:darwin": "bash scripts/setup-backend.sh",
    "setup:backend:linux": "bash scripts/setup-backend.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "run-script-os": "^1.1.6"
  }
}
